rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Teachers (moe.edu.sg) can upload quiz content images
    match /quiz-content/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.auth.token.email != null
                   && request.auth.token.email.lower().matches('.*@moe\\.edu\\.sg$')
                   && request.resource.contentType.matches('image/(png|jpeg|jpg|gif)')
                   && request.resource.size < 10 * 1024 * 1024;
    }
    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
