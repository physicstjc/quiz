rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Teachers (moe.edu.sg) can upload quiz content images
    match /quiz-content/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email.lower().matches('.*@moe\\.edu\\.sg');
    }
    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
